{
  "name": "brandforge",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "setup": "node setup.js",
    "setup:prod": "node setup-prod.js",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "migrate": "node scripts/migrate-render.js"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "npm@10.8.2"
}
