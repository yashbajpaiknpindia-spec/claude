# ================================================================
# BrandForge — Environment Variables
# No Supabase. Phone + password auth. Everything on Render.
# ================================================================

# ─── Backend (apps/api/.env) ────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Render PostgreSQL (auto-set in production — only needed locally)
DATABASE_URL=postgresql://postgres:password@localhost:5432/brandforge

# JWT secret (use a long random string — auto-generated on Render)
JWT_SECRET=change-this-to-a-long-random-string-in-production

# AI
ANTHROPIC_API_KEY=sk-ant-...

# Admin panel password
ADMIN_PASSWORD=Yash@123

# Vercel (optional — for user portfolio deployment feature)
VERCEL_TOKEN=

# ─── Frontend (apps/web/.env.local) ─────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ─── Production (set in Render dashboard) ────────────────────────
# DATABASE_URL     → auto-set by Render
# JWT_SECRET       → auto-generated by Render
# FRONTEND_URL     → auto-set by Render
# NEXT_PUBLIC_API_URL → auto-set by Render
